<!DOCTYPE html><html class="light" lang="en"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Strategic Preferences | ApplyOS</title>
<!-- Google Fonts & Material Symbols -->
<link href="https://fonts.googleapis.com" rel="preconnect">
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect">
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&amp;family=Inter:wght@400;500;600&amp;family=JetBrains+Mono:wght@500&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-background": "#011d35",
                        "surface-dim": "#c4dcfd",
                        "surface-container": "#e4efff",
                        "secondary": "#46617b",
                        "background": "#f8f9ff",
                        "tertiary": "#7b2600",
                        "on-secondary-fixed-variant": "#2e4962",
                        "surface-container-low": "#eef4ff",
                        "primary-fixed-dim": "#b2c5ff",
                        "surface-container-highest": "#d1e4ff",
                        "outline-variant": "#c3c6d6",
                        "on-tertiary-fixed": "#380d00",
                        "on-tertiary": "#ffffff",
                        "on-error": "#ffffff",
                        "surface-tint": "#0c56d0",
                        "surface-bright": "#f8f9ff",
                        "on-primary-fixed": "#001848",
                        "inverse-on-surface": "#e9f1ff",
                        "on-error-container": "#93000a",
                        "on-tertiary-container": "#ffc6b2",
                        "error": "#ba1a1a",
                        "on-tertiary-fixed-variant": "#812800",
                        "inverse-surface": "#19324b",
                        "on-surface": "#011d35",
                        "surface": "#f8f9ff",
                        "surface-container-lowest": "#ffffff",
                        "on-secondary-fixed": "#001d32",
                        "inverse-primary": "#b2c5ff",
                        "tertiary-fixed-dim": "#ffb59b",
                        "tertiary-container": "#a33500",
                        "primary-container": "#0052cc",
                        "primary": "#003d9b",
                        "on-primary-fixed-variant": "#0040a2",
                        "on-primary": "#ffffff",
                        "error-container": "#ffdad6",
                        "surface-variant": "#d1e4ff",
                        "surface-container-high": "#dbe9ff",
                        "tertiary-fixed": "#ffdbcf",
                        "secondary-fixed-dim": "#aec9e7",
                        "on-primary-container": "#c4d2ff",
                        "on-surface-variant": "#434654",
                        "on-secondary": "#ffffff",
                        "outline": "#737685",
                        "secondary-fixed": "#cee5ff",
                        "on-secondary-container": "#48637d",
                        "primary-fixed": "#dae2ff",
                        "secondary-container": "#c4e0fe"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "margin-desktop": "40px",
                        "container-max": "1440px",
                        "gutter": "24px",
                        "margin-mobile": "16px",
                        "base": "8px"
                    },
                    "fontFamily": {
                        "headline-md": ["Hanken Grotesk"],
                        "headline-lg": ["Hanken Grotesk"],
                        "label-md": ["JetBrains Mono"],
                        "headline-xl": ["Hanken Grotesk"],
                        "headline-lg-mobile": ["Hanken Grotesk"],
                        "body-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "label-md": ["12px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "500"}],
                        "headline-xl": ["40px", {"lineHeight": "48px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "headline-lg-mobile": ["28px", {"lineHeight": "36px", "fontWeight": "600"}],
                        "body-sm": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .custom-shadow {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        }
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #d1e4ff;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #aec9e7;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex overflow-hidden">
<!-- Sidebar Navigation -->
<aside class="fixed left-0 top-0 h-full w-64 bg-surface-container-lowest border-r border-outline-variant/30 flex flex-col py-margin-desktop px-4 z-50">
<div class="px-4 mb-10">
<h1 class="font-headline-md text-headline-md font-bold text-primary">ApplyOS</h1>
<p class="font-label-md text-[10px] uppercase tracking-widest text-on-surface-variant opacity-60">Executive Workbench</p>
</div>
<nav class="flex-1 space-y-1">
<a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container rounded-xl transition-all duration-200" href="#">
<span class="material-symbols-outlined text-xl" data-icon="description">description</span>
<span class="font-label-md text-label-md">Resume</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 bg-primary/5 text-primary border-r-4 border-primary rounded-l-xl font-semibold transition-all duration-200" href="#">
<span class="material-symbols-outlined text-xl" data-icon="settings_suggest">settings_suggest</span>
<span class="font-label-md text-label-md">Preferences</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container rounded-xl transition-all duration-200" href="#">
<span class="material-symbols-outlined text-xl" data-icon="explore">explore</span>
<span class="font-label-md text-label-md">North Star</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container rounded-xl transition-all duration-200" href="#">
<span class="material-symbols-outlined text-xl" data-icon="business">business</span>
<span class="font-label-md text-label-md">Companies</span>
</a>
</nav>
<div class="pt-8 border-t border-outline-variant/30 space-y-1">
<a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container rounded-xl transition-all" href="#">
<span class="material-symbols-outlined text-xl" data-icon="contact_support">contact_support</span>
<span class="font-label-md text-label-md">Support</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-surface-variant hover:bg-surface-container rounded-xl transition-all" href="#">
<span class="material-symbols-outlined text-xl" data-icon="help">help</span>
<span class="font-label-md text-label-md">Help Center</span>
</a>
<div class="mt-8 px-4 py-4 flex items-center gap-3 bg-surface-container-low rounded-2xl">
<div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold text-sm">
                JD
            </div>
<div class="overflow-hidden">
<p class="font-label-md text-xs font-bold truncate">Executive User</p>
<p class="text-[10px] text-on-surface-variant">Step 2 of 4</p>
</div>
</div>
</div>
</aside>
<!-- Main Content Area -->
<main class="ml-64 flex-1 flex flex-col h-screen relative bg-background overflow-hidden">
<!-- Header (Matching SCREEN_28 top right) -->
<header class="sticky top-0 z-40 bg-background/80 backdrop-blur-md px-margin-desktop h-20 flex items-center justify-end border-b border-outline-variant/20">
<div class="flex items-center gap-6">
<div class="flex items-center gap-2 text-on-surface-variant text-sm">
<span class="material-symbols-outlined text-lg" data-icon="lock">lock</span>
<span class="">Data encrypted &amp; private</span>
</div>
<div class="h-6 w-px bg-outline-variant/40"></div>
<button class="px-6 py-2 bg-primary text-white font-bold rounded-lg text-sm hover:bg-primary-container transition-all">
                Save &amp; Exit
            </button>
</div>
</header>
<!-- Scrollable Content -->
<div class="flex-1 overflow-y-auto px-margin-desktop py-12">
<div class="max-w-5xl mx-auto space-y-12 pb-32">
<!-- Breadcrumbs and Title (Matching SCREEN_28) -->
<div class="space-y-4">
<div class="flex items-center justify-between">
<p class="font-label-md text-xs uppercase tracking-[0.2em] text-primary font-bold">ONBOARDING · STAGE 2</p>
<!-- Horizontal Stepper Consistent with Onboarding -->
<div class="flex flex-col items-end gap-2">
<div class="flex items-center gap-1.5">
<div class="w-8 h-1.5 rounded-full bg-primary"></div>
<div class="w-8 h-1.5 rounded-full bg-primary"></div>
<div class="w-8 h-1.5 rounded-full bg-outline-variant opacity-30"></div>
<div class="w-8 h-1.5 rounded-full bg-outline-variant opacity-30"></div>
</div>
<p class="text-[10px] text-on-surface-variant font-medium">Step 2 of 4: Preferences</p>
</div>
</div>


</div>
<!-- Content Area Matching SCREEN_15 layout -->
<div class="grid grid-cols-1 gap-gutter">
<!-- Section 1: Role & Compensation (Full Width layout from SCREEN_15) -->
<section class="bg-surface-container-lowest p-8 rounded-3xl border border-outline-variant/20 custom-shadow space-y-8">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-xl bg-primary/5 flex items-center justify-center">
<span class="material-symbols-outlined text-primary" data-icon="work_outline">work_outline</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface">Role &amp; Compensation</h3>
</div>
<div class="space-y-8">
<div class="space-y-3">
<label class="font-label-md text-label-md text-on-surface-variant">Job Titles</label>
<div class="flex flex-wrap gap-2 p-3 bg-surface-container-low border border-outline-variant/30 rounded-2xl min-h-[56px] items-center">
<span class="px-3 py-1.5 bg-secondary-container text-on-secondary-container text-sm rounded-full font-medium flex items-center gap-2">
                                    VP of Engineering
                                    <button class="material-symbols-outlined text-sm opacity-60 hover:opacity-100" data-icon="close">close</button>
</span>
<span class="px-3 py-1.5 bg-secondary-container text-on-secondary-container text-sm rounded-full font-medium flex items-center gap-2">
                                    CTO
                                    <button class="material-symbols-outlined text-sm opacity-60 hover:opacity-100" data-icon="close">close</button>
</span>
<span class="px-3 py-1.5 bg-secondary-container text-on-secondary-container text-sm rounded-full font-medium flex items-center gap-2">
                                    Head of Platform
                                    <button class="material-symbols-outlined text-sm opacity-60 hover:opacity-100" data-icon="close">close</button>
</span>
<input class="bg-transparent border-none outline-none focus:ring-0 text-body-sm flex-1 min-w-[120px] placeholder:text-on-surface-variant/40" placeholder="Add title..." type="text">
</div>
</div>
<div class="space-y-3">
<label class="font-label-md text-label-md text-on-surface-variant">Minimum Base Salary (Annual)</label>
<div class="relative">
<span class="absolute left-5 top-1/2 -translate-y-1/2 text-on-surface-variant font-bold text-lg">$</span>
<input class="w-full pl-10 pr-5 py-4 bg-surface-container-low border border-outline-variant/30 rounded-2xl focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all outline-none font-headline-md text-on-surface" type="number" value="250000">
</div>
</div>
</div>
</section>
<!-- Section 2: Market Focus (Layout from SCREEN_15) -->
<section class="bg-surface-container-lowest p-8 rounded-3xl border border-outline-variant/20 custom-shadow space-y-8">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-xl bg-primary/5 flex items-center justify-center">
<span class="material-symbols-outlined text-primary" data-icon="public">public</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface">Market Focus</h3>
</div>
<div class="space-y-10">
<div class="space-y-4">
<label class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Preferred Locations</label>
<div class="flex flex-wrap gap-3">
<button class="px-6 py-2.5 border border-outline-variant/40 rounded-full text-body-sm font-semibold hover:border-primary hover:bg-primary/5 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-lg" data-icon="add">add</span> San Francisco
                                </button>
<button class="px-6 py-2.5 bg-primary text-white rounded-full text-body-sm font-semibold flex items-center gap-2 shadow-lg shadow-primary/20">
<span class="material-symbols-outlined text-lg" data-icon="check">check</span> Remote
                                </button>
<button class="px-6 py-2.5 border border-outline-variant/40 rounded-full text-body-sm font-semibold hover:border-primary hover:bg-primary/5 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-lg" data-icon="add">add</span> New York
                                </button>
<button class="px-6 py-2.5 border border-outline-variant/40 rounded-full text-body-sm font-semibold hover:border-primary hover:bg-primary/5 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-lg" data-icon="add">add</span> London
                                </button>
</div>
</div>
<div class="space-y-4">
<label class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Domains of Interest</label>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
<div class="p-6 border-2 border-primary bg-primary/5 rounded-2xl flex flex-col gap-4 cursor-pointer transition-all">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="bolt">bolt</span>
<span class="font-body-md font-bold text-on-surface">AI/ML</span>
</div>
<div class="p-6 border border-outline-variant/30 bg-surface-container-low hover:border-primary/50 rounded-2xl flex flex-col gap-4 cursor-pointer transition-all group">
<span class="material-symbols-outlined text-on-surface-variant text-3xl group-hover:text-primary transition-colors" data-icon="payments">payments</span>
<span class="font-body-md font-medium text-on-surface">FinTech</span>
</div>
<div class="p-6 border border-outline-variant/30 bg-surface-container-low hover:border-primary/50 rounded-2xl flex flex-col gap-4 cursor-pointer transition-all group">
<span class="material-symbols-outlined text-on-surface-variant text-3xl group-hover:text-primary transition-colors" data-icon="cloud">cloud</span>
<span class="font-body-md font-medium text-on-surface">Enterprise SaaS</span>
</div>
<div class="p-6 border border-outline-variant/30 bg-surface-container-low hover:border-primary/50 rounded-2xl flex flex-col gap-4 cursor-pointer transition-all group">
<span class="material-symbols-outlined text-on-surface-variant text-3xl group-hover:text-primary transition-colors" data-icon="health_and_safety">health_and_safety</span>
<span class="font-body-md font-medium text-on-surface">HealthTech</span>
</div>
</div>
</div>
</div>
</section>
<!-- Section 3: Organizational Boundary (Layout from SCREEN_15) -->
<section class="bg-surface-container-lowest p-8 rounded-3xl border border-outline-variant/20 custom-shadow space-y-6">
<div class="flex items-center gap-4">
<div class="w-10 h-10 rounded-xl bg-error/5 flex items-center justify-center">
<span class="material-symbols-outlined text-error" data-icon="block">block</span>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface">Organizational Boundary</h3>
</div>
<div class="space-y-4">
<label class="font-label-md text-label-md text-on-surface-variant">Companies to Exclude</label>
<p class="text-body-sm text-on-surface-variant leading-relaxed">Our AI will automatically filter these organizations from your search results.</p>
<div class="flex flex-wrap gap-2 p-3 bg-error/5 border border-error/20 rounded-2xl min-h-[56px] items-center">
<span class="px-3 py-1.5 bg-error-container text-on-error-container text-xs rounded-lg font-bold flex items-center gap-2">
                                Current Employer
                                <button class="material-symbols-outlined text-sm" data-icon="close">close</button>
</span>
<input class="bg-transparent border-none outline-none focus:ring-0 text-body-sm flex-1 min-w-[240px] placeholder:text-error/40" placeholder="Add company name to blacklist..." type="text">
</div>
</div>
</section>
</div>
<!-- Encryption Message -->
<div class="bg-surface-container-low/50 border border-outline-variant/20 rounded-2xl p-8 flex items-center justify-between">
<div class="flex items-center gap-4 text-on-surface-variant/70">
<span class="material-symbols-outlined text-xl" data-icon="lock">lock</span>
<p class="text-sm font-medium">All preference data is encrypted and private to your account.</p>
</div>
</div>
</div>
</div>
<!-- Sticky Footer Navigation -->
<footer class="absolute bottom-0 left-0 right-0 h-24 bg-background/95 backdrop-blur-xl border-t border-outline-variant/20 px-margin-desktop flex items-center justify-between z-50">
<button class="flex items-center gap-3 px-8 py-3.5 border border-outline-variant text-on-surface-variant rounded-xl font-bold hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined text-lg" data-icon="arrow_back">arrow_back</span>
            Previous Step
        </button>
<button class="flex items-center gap-3 px-12 py-4 bg-primary text-white rounded-xl font-bold shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all">
            Continue to North Star
            <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
</button>
</footer>
</main>
<script>
    // interaction logic for domain cards
    document.querySelectorAll('.cursor-pointer').forEach(card => {
        card.addEventListener('click', () => {
            const isSelected = card.classList.contains('border-primary');
            if (isSelected) {
                card.classList.remove('border-2', 'border-primary', 'bg-primary/5');
                card.classList.add('border', 'border-outline-variant/30', 'bg-surface-container-low');
                card.querySelector('.material-symbols-outlined').classList.remove('text-primary');
                card.querySelector('.material-symbols-outlined').classList.add('text-on-surface-variant');
                card.querySelector('span:last-child').classList.remove('font-bold');
                card.querySelector('span:last-child').classList.add('font-medium');
            } else {
                card.classList.add('border-2', 'border-primary', 'bg-primary/5');
                card.classList.remove('border', 'border-outline-variant/30', 'bg-surface-container-low');
                card.querySelector('.material-symbols-outlined').classList.add('text-primary');
                card.querySelector('.material-symbols-outlined').classList.remove('text-on-surface-variant');
                card.querySelector('span:last-child').classList.add('font-bold');
                card.querySelector('span:last-child').classList.remove('font-medium');
            }
        });
    });
</script>


</body></html>